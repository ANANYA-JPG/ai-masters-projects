        "\n",
        "    print(\"\\n🚀 Starting language predictions...\")\n",
        "    for image_path in test_files:\n",
        "        try:\n",
        "            predict_language(model, image_path, CLASS_NAMES, transform)\n",
        "        except Exception as e:\n",
        "            print(f\"❌ Failed to process {image_path}: {e}\")"

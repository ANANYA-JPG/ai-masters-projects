        "import torch\n",
        "import torch.nn as nn\n",
        "from torchvision import transforms\n",
        "from PIL import Image\n",
        "import numpy as np\n",
        "import torch.nn.functional as F\n",
        "\n",
        "# 1. Enhanced Model Architecture (matches training version)\n",
        "class LanguageIdentificationCNN(nn.Module):\n",
        "    def __init__(self, num_classes):\n",
        "        super().__init__()\n",
        "\n",
        "        self.features = nn.Sequential(\n",
        "            # Block 1\n",
        "            nn.Conv2d(1, 64, kernel_size=3, padding=1),\n",
        "            nn.BatchNorm2d(64),\n",
        "            nn.ReLU(),\n",
        "            nn.MaxPool2d(2, 2),\n",
        "\n",
        "            # Block 2\n",
        "            nn.Conv2d(64, 128, kernel_size=3, padding=1),\n",
        "            nn.BatchNorm2d(128),\n",
        "            nn.ReLU(),\n",
        "            nn.MaxPool2d(2, 2),\n",
        "\n",
        "            # Block 3\n",
        "            nn.Conv2d(128, 256, kernel_size=3, padding=1),\n",
        "            nn.BatchNorm2d(256),\n",
        "            nn.ReLU(),\n",
        "            nn.MaxPool2d(2, 2),\n",
        "\n",
        "            # Block 4\n",
        "            nn.Conv2d(256, 512, kernel_size=3, padding=1),\n",
        "            nn.BatchNorm2d(512),\n",
        "            nn.ReLU(),\n",
        "            nn.MaxPool2d(2, 2)\n",
        "        )\n",
        "\n",
        "        self.classifier = nn.Sequential(\n",
        "            nn.Linear(512 * 8 * 8, 1024),\n",
        "            nn.ReLU(),\n",
        "            nn.Dropout(0.5),\n",
        "            nn.Linear(1024, 512),\n",
        "            nn.ReLU(),\n",
        "            nn.Dropout(0.3),\n",
        "            nn.Linear(512, num_classes)\n",
        "        )\n",
        "\n",
        "    def forward(self, x):\n",
        "        x = self.features(x)\n",
        "        x = torch.flatten(x, 1)\n",
        "        x = self.classifier(x)\n",
        "        return x\n",
        "\n",
        "# 2. Configuration (update these to match your training)\n",
        "NUM_CLASSES = 4  # Update with your actual number of classes\n",
        "CLASS_NAMES = ['chinese', 'english', 'hindi','spanish']  # Update with your actual class names\n",
        "MODEL_PATH = \"final_language_model.pth\"  # Update if you used different path\n",
        "\n",
        "# 3. Transform (must exactly match training)\n",
        "transform = transforms.Compose([\n",
        "    transforms.Grayscale(num_output_channels=1),  # Convert to grayscale first\n",
        "    transforms.Resize((128, 128)),               # Then resize\n",
        "    transforms.ToTensor(),                       # Then convert to tensor\n",
        "    transforms.Normalize((0.5,), (0.5,))         # Finally normalize\n",
        "])\n",
        "\n",
        "# 4. Load model function with error handling\n",
        "def load_model(model_path, num_classes):\n",
        "    model = LanguageIdentificationCNN(num_classes)\n",
        "    try:\n",
        "        model.load_state_dict(torch.load(model_path, map_location=torch.device('cpu')))\n",
        "        model.eval()\n",
        "        print(f\"✅ Model loaded successfully from {model_path}\")\n",
        "        return model\n",
        "    except Exception as e:\n",
        "        print(f\"❌ Error loading model: {e}\")\n",
        "        raise\n",
        "\n",
        "# 5. Enhanced prediction function\n",
        "def predict_language(model, image_path, class_names, transform):\n",
        "    try:\n",
        "        # Open and validate image\n",
        "        img = Image.open(image_path)\n",
        "        if img.mode != 'RGB' and img.mode != 'L':\n",
        "            img = img.convert('RGB')\n",
        "\n",
        "        # Apply transforms\n",
        "        input_tensor = transform(img).unsqueeze(0)\n",
        "\n",
        "        # Predict\n",
        "        with torch.no_grad():\n",
        "            output = model(input_tensor)\n",
        "            probs = torch.softmax(output, dim=1).squeeze()\n",
        "            conf, predicted_idx = torch.max(probs, dim=0)\n",
        "            predicted_class = class_names[predicted_idx.item()]\n",
        "\n",
        "        # Format probabilities for display\n",
        "        prob_dict = {class_names[i]: f\"{probs[i].item():.2%}\"\n",
        "                    for i in range(len(class_names))}\n",
        "\n",
        "        print(f\"\\n📄 File: {image_path}\")\n",
        "        print(f\"🔍 Predicted language: {predicted_class} (confidence: {conf.item():.2%})\")\n",
        "        print(\"📊 Probabilities:\")\n",
        "        for lang, prob in prob_dict.items():\n",
        "            print(f\"  {lang}: {prob}\")\n",
        "\n",
        "        return predicted_class, probs.numpy()\n",
        "\n",
        "    except Exception as e:\n",
        "        print(f\"❌ Error processing {image_path}: {e}\")\n",
        "        return None, None\n",
        "\n",
        "# 6. Main execution\n",
        "if __name__ == \"__main__\":\n",
        "    # Load model\n",
        "    model = load_model(MODEL_PATH, NUM_CLASSES)\n",
        "\n",
        "    # Example files to predict (update with your paths)\n",
